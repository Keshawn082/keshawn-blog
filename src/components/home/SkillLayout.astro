---
import Button from '@/components/Button.astro'

type Props = {
  title: string
  skills: string[]
  ['data-i18n-section']?: string
}

const { title, skills } = Astro.props
const i18nSection = Astro.props['data-i18n-section']
---

<div class='flex flex-col gap-y-2 md:flex-row md:gap-x-5 md:gap-y-0'>
  <h3 class='w-1/5 font-medium' data-i18n={i18nSection}>{title}</h3>
  <div class='flex flex-row flex-wrap gap-x-4 gap-y-2 md:w-4/5'>
    {skills.map((skill: string) => (
        <Button as='button' title={skill} variant='pill' i18n={`skill.${skill}`} />
      ))}
  </div>
</div>
