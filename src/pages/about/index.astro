---
import { Timeline } from 'astro-pure/user'
import Button from '@/components/Button.astro'
import PageLayout from '@/layouts/CommonPage.astro'
import Substats from '@/components/about/Substats.astro'
import ToolSection from '@/components/about/ToolSection.astro'
import hermesIcon from '@/assets/tools/hermes.png'
import openaiIcon from '@/assets/tools/openai.png'
import chatgptIcon from '@/assets/tools/chatgpt.png'
import claudeCodeIcon from '@/assets/tools/claude-code.png'
import cozeIcon from '@/assets/tools/coze.png'
import comfyuiIcon from '@/assets/tools/comfyui.png'
import langgraphIcon from '@/assets/tools/langgraph.png'
import llamaindexIcon from '@/assets/tools/llamaindex.png'
import pythonIcon from '@/assets/tools/python.png'
import typescriptIcon from '@/assets/tools/typescript.png'
import fastapiIcon from '@/assets/tools/fastapi.png'
import dockerIcon from '@/assets/tools/docker.png'
import vercelIcon from '@/assets/tools/vercel.png'
import gitIcon from '@/assets/tools/git.png'

const headings = [
  { depth: 2, slug: 'hobbies', text: 'Hobbies' },
  { depth: 2, slug: 'tools', text: 'Tools' },
  { depth: 2, slug: 'social-networks', text: 'Social Networks' },
  { depth: 2, slug: 'about-blog', text: 'About Blog' }
]
---

<PageLayout title='关于' data-i18n-title='about.title' {headings} comment>
  <p data-i18n='about.description'>Agent 全栈开发工程师</p>
  <p data-i18n='about.bio'>
    中南大学智能科学与技术硕士，专注于大模型应用开发与 AI Agent 工程化落地。
    熟悉 Agent 工作流设计、多 Agent 协作、RAG 应用构建等技术，持续探索前沿 AI 工程实践。
  </p>
  <p>
    <span data-i18n='about.motto.prefix'>座右铭：</span><span data-i18n='about.motto.text'>Keep building, keep shipping.</span>
  </p>
  <Button class='w-fit' href='/projects#sponsorship' variant='ahead'>
    <span data-i18n='about.sponsor'>赞助我</span>
  </Button>

  {/* general-talk */}
  <h2 id='hobbies' data-i18n='about.hobbies'>兴趣爱好</h2>
  <ul>
    <li data-i18n='about.hobby1'>AI Agent 框架调研与工程实践</li>
    <li data-i18n='about.hobby2'>RAG 与检索系统优化</li>
    <li data-i18n='about.hobby3'>多 Agent 协作系统设计</li>
    <li data-i18n='about.hobby4'>阅读前沿论文与技术博客</li>
  </ul>

  {/* tools */}
  <h2 id='tools' data-i18n='about.tools'>工具</h2>
  <p data-i18n='about.social.current_tools'>当前支持以下工具：</p>
  <ToolSection
    class='mb-5'
    title='AI 与 Agent'
    data-i18n-title='about.tools.ai'
    tools={[
      {
        name: 'OpenAI API',
        description: 'LLM 服务',
        href: 'https://github.com/openai/openai-python',
        icon: openaiIcon
      },
      {
        name: 'ChatGPT',
        description: 'AI 助手',
        href: 'https://openai.com/zh-Hans-CN/codex/',
        icon: chatgptIcon
      },
      {
        name: 'Claude Code',
        description: 'AI 编码助手',
        href: 'https://claude.com/product/claude-code',
        icon: claudeCodeIcon
      },
      {
        name: 'Hermes Agent',
        description: 'Agent 框架',
        href: 'https://hermes-agent.nousresearch.com/',
        icon: hermesIcon
      },
      {
        name: 'LangGraph',
        description: 'Agent 编排框架',
        href: 'https://github.com/langchain-ai/langgraph',
        icon: langgraphIcon
      },
      {
        name: 'LlamaIndex',
        description: 'RAG 框架',
        href: 'https://github.com/run-llama/llama_index',
        icon: llamaindexIcon
      },
      {
        name: 'Coze',
        description: 'Agent 搭建平台',
        href: 'https://www.coze.cn/overview',
        icon: cozeIcon
      },
      {
        name: 'ComfyUI',
        description: 'AI 图像工作流',
        href: 'https://github.com/Comfy-Org/ComfyUI',
        icon: comfyuiIcon
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='开发工具'
    data-i18n-title='about.tools.development'
    tools={[
      {
        name: 'VS Code',
        description: 'IDE',
        href: 'https://code.visualstudio.com/',
        icon: import('@/assets/tools/vscode.svg?raw')
      },
      {
        name: 'Python',
        description: '编程语言',
        href: 'https://www.python.org/',
        icon: pythonIcon
      },
      {
        name: 'TypeScript',
        description: '编程语言',
        href: 'https://www.typescriptlang.org/',
        icon: typescriptIcon
      },
      {
        name: 'FastAPI',
        description: '后端框架',
        href: 'https://fastapi.tiangolo.com/',
        icon: fastapiIcon
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='部署与运维'
    data-i18n-title='about.tools.devops'
    tools={[
      {
        name: 'Docker',
        description: '容器化',
        href: 'https://www.docker.com/',
        icon: dockerIcon
      },
      {
        name: 'Vercel',
        description: '部署平台',
        href: 'https://vercel.com/',
        icon: vercelIcon
      },
      {
        name: 'Git',
        description: '版本控制',
        href: 'https://git-scm.com/',
        icon: gitIcon
      },
      {
        name: 'Astro',
        description: '静态站点框架',
        href: 'https://astro.build/',
        icon: import('@/assets/tools/astro.svg?raw')
      }
    ]}
  />

  {/* social-networks */}
  <h2 id='social-networks' data-i18n='about.social'>社交网络</h2>
  <p>你可以在以下平台找到我：</p>
  <Substats
    stats={[
      {
        platform: 'GitHub',
        icon: 'github',
        link: 'https://github.com/keshawn082',
        text: 'repositories',
        api: 'github/keshawn082'
      }
    ]}
  />

  {/* about-blog */}
  <h2 id='about-blog' data-i18n='about.blog'>关于博客</h2>
  <p data-i18n='about.blog.website_history'>网站历史：</p>
  <Timeline
    events={[
      {
        date: '2026-07',
        content:
          '部署个人博客 <a href="https://keshawn.cn" target="_blank">keshawn.cn</a>，使用 <a href="https://astro.build/" target="_blank">Astro</a> 和 <a href="https://github.com/cworld1/astro-theme-pure" target="_blank">Astro Theme Pure</a> 搭建，托管于 <a href="https://vercel.com/" target="_blank">Vercel</a>'
      }
    ]}
  />
  <p data-i18n='about.blog.credits'>
    网站的稳定运行和个性化定制也依赖于以下优秀项目/服务提供商提供的资源和技术支持：
  </p>
  <ul>
    <li>Domain: <a href='https://keshawn.cn' target='_blank'>keshawn.cn</a></li>
    <li>
      Framework & Theme: <a href='https://astro.build/' target='_blank'>Astro</a> + <a
        href='https://github.com/cworld1/astro-theme-pure'
        target='_blank'>Astro Theme Pure</a
      >
    </li>
    <li>
      Site hosting: <a href='https://vercel.com/' target='_blank'>Vercel</a>
    </li>
  </ul>
</PageLayout>
