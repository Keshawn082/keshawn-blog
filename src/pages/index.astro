---
import { Image } from 'astro:assets'

import { Quote } from 'astro-pure/advanced'
import { PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import { Icon } from 'astro-pure/user'
import Button from '@/components/Button.astro'
import Label from '@/components/Label.astro'
import PageLayout from '@/layouts/BaseLayout.astro'
import ProjectCard from '@/components/home/ProjectCard.astro'
import Section from '@/components/home/Section.astro'
import SkillLayout from '@/components/home/SkillLayout.astro'
import chaojiIcon from '@/assets/companies/chaoji.png'
import wengeIcon from '@/assets/companies/wenge.png'
import wondershareIcon from '@/assets/companies/wondershare.png'
import csuIcon from '@/assets/schools/csu.png'
import xjuIcon from '@/assets/schools/xju.png'
import config from '@/site-config'

const languages = ['Python', 'TypeScript', 'JavaScript', 'SQL', 'HTML', 'CSS', 'Shell']
const aiAgent = ['Claude Code', 'Hermes', 'Function Calling', 'Prompt Engineering', 'Harness Engineering', 'Loop Engineering']
const tools = ['FastAPI', 'Astro', 'Vite', 'Git', 'Docker', 'Vercel']

const MAX_POSTS = 10
const allPosts = await getBlogCollection()
const allPostsByDate = sortMDByDate(allPosts).slice(0, MAX_POSTS)

const imagePath = config.logo.src
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/*.{jpeg,jpg,png,gif,avif,webp}'
)
if (!images[imagePath])
  throw new Error(
    `"${imagePath}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif,avif,webp}"`
  )
---

<PageLayout meta={{ title: 'Home' }} highlightColor='#659EB9'>
  <main class='flex w-full flex-col items-center'>
    <section class='animate mb-10 flex flex-col items-center gap-y-7' id='content-header'>
      <Image
        src={images[imagePath]()}
        alt={config.logo.alt || 'Profile'}
        class='h-28 w-auto rounded-full border p-1'
        loading='eager'
        fetchpriority='high'
      />

      <div class='flex flex-col items-center gap-y-4'>
        <h1 class='text-3xl font-medium'>{config.author}</h1>
        <div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
          <Label title=''>
            <Icon name='location' class='size-5' slot='icon' />
            <span data-i18n='home.location'>长沙</span>
          </Label>
          <Label
            title=''
            as='a'
            href='https://github.com/Keshawn082/keshawn-blog'
            target='_blank'
          >
            <Icon name='github' class='size-5' slot='icon' />
            <span data-i18n='home.source_code'>源代码</span>
          </Label>
        </div>
      </div>

    </section>

    <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      <Section title='关于' data-i18n-section='home.about'>
        <p class='text-muted-foreground' data-i18n='home.description'>大模型应用 / Agent 开发</p>
        <p class='text-muted-foreground' data-i18n='home.bio'>
          中南大学智能科学与技术硕士在读，方向聚焦大模型应用开发。对 Agent 工作流、RAG、多 Agent 协作等有一定实践经验，热衷于用技术解决实际问题。
        </p>
        <Button class='w-fit self-end' href='/about' variant='ahead'>
          <span data-i18n='home.more_about'>了解更多</span>
        </Button>
      </Section>
      <Section title='教育' data-i18n-section='home.education'>
        <div class='not-prose flex flex-col gap-3'>
          <a
            href='https://www.csu.edu.cn'
            class='group relative block rounded-2xl border bg-muted px-5 py-4 transition-all hover:border-foreground/25 hover:shadow-sm'
            target='_blank'
          >
            <div class='grid gap-2 sm:grid-cols-[1fr_auto] sm:items-start sm:gap-x-6'>
              <div class='min-w-0 space-y-1'>
                <div class='flex flex-wrap items-center gap-2'>
                  <Image src={csuIcon} alt='中南大学' class='size-6 rounded-md object-contain' />
                  <h2 class='text-lg font-medium leading-tight' data-i18n='home.edu.csu.heading'>中南大学</h2>
                  <span class='rounded-md border bg-background px-1.5 py-0.5 text-xs text-muted-foreground' data-i18n='home.edu.tag.985'>985院校</span>
                  <span class='rounded-md border bg-background px-1.5 py-0.5 text-xs text-muted-foreground' data-i18n='home.edu.tag.double_first_class'>双一流院校</span>
                </div>
                <p class='text-muted-foreground' data-i18n='home.edu.csu.subheading'>智能科学与技术 · 硕士</p>
              </div>
              <p class='whitespace-nowrap text-sm text-muted-foreground sm:pt-1 sm:text-right' data-i18n='home.edu.csu.date'>2024年9月 - 2027年6月</p>
            </div>
          </a>

          <a
            href='https://www.xju.edu.cn'
            class='group relative block rounded-2xl border bg-muted px-5 py-4 transition-all hover:border-foreground/25 hover:shadow-sm'
            target='_blank'
          >
            <div class='grid gap-2 sm:grid-cols-[1fr_auto] sm:items-start sm:gap-x-6'>
              <div class='min-w-0 space-y-1'>
                <div class='flex flex-wrap items-center gap-2'>
                  <Image src={xjuIcon} alt='新疆大学' class='size-6 rounded-md object-contain' />
                  <h2 class='text-lg font-medium leading-tight' data-i18n='home.edu.xju.heading'>新疆大学</h2>
                  <span class='rounded-md border bg-background px-1.5 py-0.5 text-xs text-muted-foreground' data-i18n='home.edu.tag.211'>211院校</span>
                  <span class='rounded-md border bg-background px-1.5 py-0.5 text-xs text-muted-foreground' data-i18n='home.edu.tag.double_first_class'>双一流院校</span>
                </div>
                <p class='text-muted-foreground' data-i18n='home.edu.xju.subheading'>采矿工程 · 本科</p>
              </div>
              <p class='whitespace-nowrap text-sm text-muted-foreground sm:pt-1 sm:text-right' data-i18n='home.edu.xju.date'>2020年9月 - 2024年6月</p>
            </div>
          </a>
        </div>
      </Section>

      <Section title='实习' data-i18n-section='home.internships'>
        <div class='not-prose flex flex-col gap-3'>
          <a
            href='https://marketing.k-fashionshop.com/'
            class='relative block rounded-2xl border bg-muted px-5 py-4 transition-all hover:border-foreground/25 hover:shadow-sm'
            target='_blank'
          >
            <div class='grid gap-2 sm:grid-cols-[1fr_auto] sm:items-start sm:gap-x-6'>
              <div class='min-w-0 space-y-1.5'>
                <div class='flex flex-wrap items-center gap-2'>
                  <Image src={chaojiIcon} alt='潮际汇' class='size-6 rounded-md object-contain' />
                  <h2 class='text-lg font-medium leading-tight' data-i18n='home.intern.chaoji.company'>潮际汇（杭州）智能科技有限公司</h2>
                  <span class='rounded-md border bg-background px-1.5 py-0.5 text-xs text-muted-foreground' data-i18n='home.intern.tag.ai_app'>AI应用企业</span>
                </div>
                <p class='text-muted-foreground' data-i18n='home.intern.chaoji.business'>人工智能技术开发与应用</p>
                <p class='font-medium text-foreground' data-i18n='home.intern.chaoji.role'>Agent开发实习生</p>
              </div>
              <p class='whitespace-nowrap text-sm text-muted-foreground sm:pt-1 sm:text-right' data-i18n='home.intern.chaoji.date'>2026年6月 - 2026年9月</p>
            </div>
          </a>

          <a
            href='https://www.wondershare.cn/'
            class='relative block rounded-2xl border bg-muted px-5 py-4 transition-all hover:border-foreground/25 hover:shadow-sm'
            target='_blank'
          >
            <div class='grid gap-2 sm:grid-cols-[1fr_auto] sm:items-start sm:gap-x-6'>
              <div class='min-w-0 space-y-1.5'>
                <div class='flex flex-wrap items-center gap-2'>
                  <Image src={wondershareIcon} alt='万兴科技' class='size-6 rounded-md object-contain' />
                  <h2 class='text-lg font-medium leading-tight' data-i18n='home.intern.wondershare.company'>万兴科技集团股份有限公司</h2>
                  <span class='rounded-md border bg-background px-1.5 py-0.5 text-xs text-muted-foreground' data-i18n='home.intern.tag.a_share'>A股上市公司</span>
                </div>
                <p class='text-muted-foreground' data-i18n='home.intern.wondershare.business'>主营数字创意软件、AI精品影视内容创作</p>
                <p class='font-medium text-foreground' data-i18n='home.intern.wondershare.role'>AI应用开发实习生</p>
              </div>
              <p class='whitespace-nowrap text-sm text-muted-foreground sm:pt-1 sm:text-right' data-i18n='home.intern.wondershare.date'>2026年1月 - 2026年4月</p>
            </div>
          </a>

          <a
            href='https://ir.wenge.com/cn/'
            class='relative block rounded-2xl border bg-muted px-5 py-4 transition-all hover:border-foreground/25 hover:shadow-sm'
            target='_blank'
          >
            <div class='grid gap-2 sm:grid-cols-[1fr_auto] sm:items-start sm:gap-x-6'>
              <div class='min-w-0 space-y-1.5'>
                <div class='flex flex-wrap items-center gap-2'>
                  <Image src={wengeIcon} alt='中科闻歌' class='size-6 rounded-md object-contain' />
                  <h2 class='text-lg font-medium leading-tight' data-i18n='home.intern.wenge.company'>北京中科闻歌科技股份有限公司</h2>
                  <span class='rounded-md border bg-background px-1.5 py-0.5 text-xs text-muted-foreground' data-i18n='home.intern.tag.hkex'>港交所上市公司</span>
                </div>
                <p class='text-muted-foreground' data-i18n='home.intern.wenge.business'>人工智能认知与决策技术企业</p>
                <p class='font-medium text-foreground' data-i18n='home.intern.wenge.role'>算法实习生</p>
              </div>
              <p class='whitespace-nowrap text-sm text-muted-foreground sm:pt-1 sm:text-right' data-i18n='home.intern.wenge.date'>2025年10月 - 2025年12月</p>
            </div>
          </a>
        </div>
      </Section>

      {
        allPostsByDate.length > 0 && (
          <Section title='文章' data-i18n-section='home.posts'>
            <ul class='flex flex-col gap-y-1.5 sm:gap-y-2'>
              {allPostsByDate.map((p) => (
                <li class='flex flex-col gap-x-2 sm:flex-row'>
                  <PostPreview post={p} />
                </li>
              ))}
            </ul>
            <Button class='w-fit self-end' href='/blog' variant='ahead'>
              <span data-i18n='home.more_posts'>更多文章</span>
            </Button>
          </Section>
        )
      }

      <Section title='项目' data-i18n-section='home.projects'>
        <div class='grid grid-cols-1 gap-3 sm:grid-cols-2'>
          <ProjectCard
            href='https://keshawn.cn'
            heading='Keshawn Blog'
            subheading='个人技术博客 · Astro + Hermes Agent 主题'
            imagePath='/src/assets/projects/1.avif'
            data-i18n-subheading='home.project.keshawn_blog.subheading'
          />
          <ProjectCard
            href='/projects'
            heading='更多项目'
            subheading='查看全部项目'
            imagePath='/src/assets/projects/4.avif'
            data-i18n-heading='home.project.more.heading'
            data-i18n-subheading='home.project.more.subheading'
          />
        </div>
      </Section>

      <Section title='证书' data-i18n-section='home.certifications'>
        <ul class='flex flex-col gap-y-3'>
          <li><span data-i18n='home.cert.scholarship1'>研究生学业一等奖学金</span> <span class='text-xs text-muted-foreground' data-i18n='home.cert.date.scholarship1'>2024年</span></li>
          <li><span data-i18n='home.cert.math'>全国大学生数学竞赛省二等奖</span> <span class='text-xs text-muted-foreground' data-i18n='home.cert.date.math'>2023年</span></li>
          <li><span data-i18n='home.cert.market'>全国大学生市场调查与分析大赛省三等奖</span> <span class='text-xs text-muted-foreground' data-i18n='home.cert.date.market'>2023年</span></li>
          <li><span data-i18n='home.cert.scholarship2'>国家励志奖学金</span> <span class='text-xs text-muted-foreground' data-i18n='home.cert.date.scholarship2'>2023年</span></li>
          <li><span data-i18n='home.cert.cet6'>CET-6</span> <span class='text-xs text-muted-foreground' data-i18n='home.cert.date.cet6'>2023年</span></li>
        </ul>
      </Section>

      <Section title='技能' data-i18n-section='home.skills'>
        <SkillLayout title='编程语言' data-i18n-section='home.skills.languages' skills={languages} />
        <SkillLayout title='AI与Agent' data-i18n-section='home.skills.ai' skills={aiAgent} />
        <SkillLayout title='框架与工具' data-i18n-section='home.skills.tools' skills={tools} />
      </Section>
    </div>
    <Quote class='mt-12' />
  </main>
</PageLayout>
